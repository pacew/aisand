#!/bin/bash
set -e

# Refuse to run inside a container
if [ -f /.dockerenv ]; then
  echo "Error: aisand cannot be run inside an aisand container"
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
DOCKERFILE="$SCRIPT_DIR/Dockerfile"

if [ ! -f "$DOCKERFILE" ]; then
  echo "Error: Dockerfile not found at $DOCKERFILE"
  exit 1
fi

# A single image is shared across all aisand projects.
IMAGE_TAG="aisand"

if [ "$1" == "prune" ]; then
  echo "Removing all aisand images and volumes..."
  docker images -q --filter 'reference=aisand*' \
    | xargs --no-run-if-empty docker rmi -f
  docker volume ls -q --filter 'name=^aisand-' \
    | xargs --no-run-if-empty docker volume rm
  echo "Cleanup complete."
  exit 0
fi

if [ "$1" == "rebuild" ]; then
  echo "Deleting old image: $IMAGE_TAG"
  docker image rm "$IMAGE_TAG" 2>/dev/null || true
  # Fall through to normal build and launch
fi

# Allow .git to be either a directory (normal clone) or a file (worktree)
if [ ! -e .git ]; then
  echo "Error: Not in a git repository root (no .git found)"
  echo "Usage: cd /path/to/git/repo && aisand"
  echo "       aisand rebuild   (delete and rebuild Docker image, then launch)"
  echo "       aisand prune     (remove all aisand images and volumes)"
  exit 1
fi

if [ -z "$ANTHROPIC_API_KEY" ]; then
  echo "Error: ANTHROPIC_API_KEY not set in environment"
  echo "Set it with: export ANTHROPIC_API_KEY=\"sk-ant-...\""
  exit 1
fi

REPO_ROOT="$(pwd)"
REPO_NAME="$(basename "$REPO_ROOT")"
REPO_NAME_SAFE="$(echo -n "$REPO_NAME" | tr -c 'a-zA-Z0-9._-' '_')"
PATH_HASH="$(echo -n "$REPO_ROOT" | sha256sum | cut -c1-8)"
MEMORY_VOLUME="aisand-${REPO_NAME_SAFE}-${PATH_HASH}-memory"

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "aisand: Claude Code Sandbox"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Repository:    $REPO_ROOT"
echo "Image:         $IMAGE_TAG"
echo "Memory volume: $MEMORY_VOLUME"
echo ""

if ! docker image inspect "$IMAGE_TAG" > /dev/null 2>&1; then
  echo "Building Docker image (first run, this takes a minute)..."
  docker build -f "$DOCKERFILE" -t "$IMAGE_TAG" "$SCRIPT_DIR"
else
  echo "Using cached Docker image"
fi

# Create the memory volume if needed, and chown it to the host user so
# the non-root container process can write to it.
if ! docker volume inspect "$MEMORY_VOLUME" > /dev/null 2>&1; then
  echo "Creating memory volume..."
  docker volume create "$MEMORY_VOLUME" > /dev/null
  echo "Initializing memory volume ownership..."
  docker run --rm --user root \
    -v "$MEMORY_VOLUME:/init" \
    "$IMAGE_TAG" \
    chown "$(id -u):$(id -g)" /init
fi

# Generate /etc/passwd and /etc/group entries so the host user has a
# proper identity inside the container (no "I have no name!" prompt,
# git/npm/etc. can resolve $HOME and $USER).
PASSWD_FILE="$(mktemp)"
GROUP_FILE="$(mktemp)"
trap 'rm -f "$PASSWD_FILE" "$GROUP_FILE"' EXIT

cat > "$PASSWD_FILE" <<EOF
root:x:0:0:root:/root:/bin/bash
${USER}:x:$(id -u):$(id -g):${USER}:${HOME}:/bin/bash
EOF

cat > "$GROUP_FILE" <<EOF
root:x:0:
${USER}:x:$(id -g):
EOF

# Pre-seed Claude Code config so the first-run dialogs (onboarding, trust,
# theme, API-key approval) are answered without prompting. Re-seeded each
# run because ~/.claude.json lives in tmpfs $HOME.
#
# We copy the API-key approval list from the host's ~/.claude.json if
# present, so the same API key isn't re-prompted in the container.
API_KEY_APPROVALS='[]'
if [ -f "$HOME/.claude.json" ] && command -v python3 >/dev/null 2>&1; then
  API_KEY_APPROVALS=$(python3 - "$HOME/.claude.json" <<'PY'
import json, sys
try:
    with open(sys.argv[1]) as f:
        d = json.load(f)
    print(json.dumps(d.get('customApiKeyResponses', {}).get('approved', [])))
except Exception:
    print('[]')
PY
)
fi

CLAUDE_CONFIG=$(cat <<EOF
{
  "hasCompletedOnboarding": true,
  "theme": "dark",
  "customApiKeyResponses": {"approved": ${API_KEY_APPROVALS}, "rejected": []},
  "projects": {
    "${REPO_ROOT}": {
      "hasTrustDialogAccepted": true,
      "projectOnboardingSeenCount": 1
    }
  }
}
EOF
)

# Optional mount of host ~/.gitconfig so git commits get the host user's
# name and email. Read-only so the container can't modify it.
GITCONFIG_MOUNT=()
if [ -f "$HOME/.gitconfig" ]; then
  GITCONFIG_MOUNT=(-v "$HOME/.gitconfig:$HOME/.gitconfig:ro")
fi

echo ""
echo "Launching interactive shell..."
echo "Project: $REPO_ROOT"
echo "Exit with Ctrl+D or 'exit' to destroy the container"
echo ""

docker run --rm -it \
  --user "$(id -u):$(id -g)" \
  --hostname "aisand-${REPO_NAME_SAFE}" \
  --security-opt=no-new-privileges \
  --cap-drop=all \
  --memory=4g \
  --cpus=4 \
  --tmpfs "$HOME":uid=$(id -u),gid=$(id -g),mode=755,size=512m \
  -w "$REPO_ROOT" \
  -e HOME="$HOME" \
  -e USER="$USER" \
  -e ANTHROPIC_API_KEY="$ANTHROPIC_API_KEY" \
  -e AISAND_CLAUDE_CONFIG="$CLAUDE_CONFIG" \
  -v "$PASSWD_FILE:/etc/passwd:ro" \
  -v "$GROUP_FILE:/etc/group:ro" \
  -v "$REPO_ROOT:$REPO_ROOT" \
  -v "$MEMORY_VOLUME:$HOME/.claude" \
  "${GITCONFIG_MOUNT[@]}" \
  "$IMAGE_TAG"

echo ""
echo "Container destroyed. Project files and memory remain on disk."
